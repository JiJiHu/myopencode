{
  "version": 2,
  "builds": [
    { "src": "**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/games/angry-birds", "dest": "/games/angry-birds/index.html" },
    { "src": "/games/angry-birds/", "dest": "/games/angry-birds/index.html" },
    { "src": "/games/snake", "dest": "/games/snake/snake.html" },
    { "src": "/games/snake/", "dest": "/games/snake/snake.html" },
    { "src": "/games/gomoku", "dest": "/games/gomoku/gomoku.html" },
    { "src": "/games/gomoku/", "dest": "/games/gomoku/gomoku.html" },
    { "src": "/games/sudoku", "dest": "/games/sudoku/sudoku.html" },
    { "src": "/games/sudoku/", "dest": "/games/sudoku/sudoku.html" },
    { "src": "/games/minesweeper", "dest": "/games/minesweeper/minesweeper.html" },
    { "src": "/games/minesweeper/", "dest": "/games/minesweeper/minesweeper.html" },
    { "src": "/games/breakout", "dest": "/games/breakout/breakout.html" },
    { "src": "/games/breakout/", "dest": "/games/breakout/breakout.html" },
    { "src": "/games/(.*)", "dest": "/games/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
